# constants
w=3
# plot settings
set palette defined (0.0 'black', 0.5 'blue', 1.0 'red')
unset colorbox
set xtics font ',12'
set ytics font ',12'
set grid xtics ytics lw 0.75*w
set key center top font ',14'
set xlabel 'Argument' font ',14'
set ylabel 'Loss' font ',14'
set xzeroaxis lw w
set yzeroaxis lw w
# plot
plot [:] [:5]\
	'loss.dat' using 1:2 with lines lw w lc palette frac 0.0/2.0 title 'mse',\
	'loss.dat' using 1:3 with lines lw w lc palette frac 1.0/2.0 title 'huber',\
	'loss.dat' using 1:4 with lines lw w lc palette frac 2.0/2.0 title 'asinh'
pause -1 'continue'
